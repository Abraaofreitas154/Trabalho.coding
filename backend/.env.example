# ============================================
# CONFIGURAÇÃO PARA DEPLOY NO VERCEL + MONGODB ATLAS
# ============================================

# Porta local (ignorada pelo Vercel, que usa porta dinâmica)
PORT=3000

# MongoDB Atlas - SUBSTITUA COM SUA URI REAL
# Como obter:
# 1. Acesse https://cloud.mongodb.com
# 2. Crie um cluster gratuito (Shared/Free)
# 3. Em "Database Access", crie um usuário com senha
# 4. Em "Network Access", adicione 0.0.0.0/0 (acesso de qualquer IP)
# 5. Em "Clusters" > "Connect" > "Drivers" > "Node.js"
# 6. Copie a string de conexão e substitua <password> pela senha do usuário
#
# EXEMPLO:
# MONGODB_URI=mongodb+srv://meuusuario:minhasenha@meucluster.abc123.mongodb.net/musclefit?retryWrites=true&w=majority
#
MONGODB_URI=mongodb://localhost:27017/musclefit

# URL do frontend em produção (para CORS)
# Depois de fazer deploy do frontend, cole a URL aqui
# FRONTEND_URL=https://seu-frontend.vercel.app

# Ambiente
NODE_ENV=development

